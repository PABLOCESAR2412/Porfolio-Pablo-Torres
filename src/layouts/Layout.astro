---
import '../styles/global.css';
import { useTranslations } from '../i18n/ui';

interface Props {
  title: string;
  lang: 'es' | 'en';
}

const { title, lang } = Astro.props;
const t = useTranslations(lang);
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={t('hero.desc')} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={t('hero.desc')} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/profile.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;900&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <!-- Dark Mode Script -->
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body class="min-h-screen selection:bg-electric dark:selection:bg-bone selection:text-bone dark:selection:text-stone flex justify-center bg-bone dark:bg-stone text-pure dark:text-bone transition-colors duration-300">
    <!-- Grid System Container -->
    <div class="w-full max-w-[1440px] bg-bone dark:bg-stone border-tech border-y-0 border-x min-h-screen grid grid-cols-1 md:grid-cols-asymmetric shadow-[0_0_50px_rgba(0,0,0,0.05)] dark:shadow-[0_0_50px_rgba(0,0,0,0.5)] z-0">
      <!-- Nav/Sidebar -->
      <aside class="border-tech-b md:border-tech-b-0 md:border-tech-r p-4 md:p-8 flex flex-col md:justify-between sticky top-0 h-auto md:h-screen z-50 bg-bone dark:bg-stone transition-colors duration-300 w-full">
        <div class="flex flex-col w-full">
          <div class="mb-4 md:mb-12 flex justify-between items-center w-full">
            <p class="font-mono text-sm md:text-base text-stone dark:text-gray-400 uppercase tracking-tight font-black md:font-normal">{t('sidebar.title')}</p>
            
            <!-- Mobile Menu Toggle Button -->
            <button id="mobile-menu-btn" class="md:hidden font-mono text-sm font-bold uppercase hover:text-electric transition-colors duration-300 outline-none focus-visible:text-electric">
              [MENU]
            </button>
          </div>
          
          <nav class="hidden md:flex flex-col gap-4 font-mono text-base uppercase">
            <a href="#about" class="hover:text-electric transition-colors duration-300 before:content-['['] after:content-[']'] before:text-transparent hover:before:text-electric dark:hover:before:text-gray-300 after:text-transparent hover:after:text-electric dark:hover:after:text-gray-300 md:before:mr-1 md:after:ml-1 md:-ml-2 focus-visible:ring-1 focus-visible:ring-pure dark:focus-visible:ring-bone outline-none focus-visible:text-electric dark:focus-visible:text-electric">{t('nav.about')}</a>
            <a href="#projects" class="hover:text-electric transition-colors duration-300 before:content-['['] after:content-[']'] before:text-transparent hover:before:text-electric dark:hover:before:text-gray-300 after:text-transparent hover:after:text-electric dark:hover:after:text-gray-300 md:before:mr-1 md:after:ml-1 md:-ml-2 focus-visible:ring-1 focus-visible:ring-pure dark:focus-visible:ring-bone outline-none focus-visible:text-electric dark:focus-visible:text-electric">{t('nav.projects')}</a>
            <a href="#skills" class="hover:text-electric transition-colors duration-300 before:content-['['] after:content-[']'] before:text-transparent hover:before:text-electric dark:hover:before:text-gray-300 after:text-transparent hover:after:text-electric dark:hover:after:text-gray-300 md:before:mr-1 md:after:ml-1 md:-ml-2 focus-visible:ring-1 focus-visible:ring-pure dark:focus-visible:ring-bone outline-none focus-visible:text-electric dark:focus-visible:text-electric">{t('nav.skills')}</a>
            <a href="#experience" class="hover:text-electric transition-colors duration-300 before:content-['['] after:content-[']'] before:text-transparent hover:before:text-electric dark:hover:before:text-gray-300 after:text-transparent hover:after:text-electric dark:hover:after:text-gray-300 md:before:mr-1 md:after:ml-1 md:-ml-2 focus-visible:ring-1 focus-visible:ring-pure dark:focus-visible:ring-bone outline-none focus-visible:text-electric dark:focus-visible:text-electric">{t('nav.experience')}</a>
            <a href="#contact" class="hover:text-electric transition-colors duration-300 before:content-['['] after:content-[']'] before:text-transparent hover:before:text-electric dark:hover:before:text-gray-300 after:text-transparent hover:after:text-electric dark:hover:after:text-gray-300 md:before:mr-1 md:after:ml-1 md:-ml-2 focus-visible:ring-1 focus-visible:ring-pure dark:focus-visible:ring-bone outline-none focus-visible:text-electric dark:focus-visible:text-electric">{t('nav.contact')}</a>
          </nav>

          <!-- Desktop Controls: Theme & Lang & Font Size -->
          <div class="hidden md:flex flex-wrap gap-6 font-mono text-sm mt-12">
            <button id="theme-toggle" class="hover:text-electric transition-colors duration-300 flex items-center gap-1 focus-visible:ring-1 focus-visible:ring-pure dark:focus-visible:ring-bone outline-none">
              <!-- Sun Icon for Light Mode -->
              <svg class="dark:hidden w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
              <!-- Moon Icon for Dark Mode -->
              <svg class="hidden dark:block w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
              <span class="dark:hidden">[DARK]</span>
              <span class="hidden dark:inline">[LIGHT]</span>
            </button>
            <a href={lang === 'es' ? '/en' : '/'} class="hover:text-electric transition-colors duration-300 flex items-center gap-1 focus-visible:ring-1 focus-visible:ring-pure dark:focus-visible:ring-bone outline-none">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"></path></svg>
              [{lang === 'es' ? 'EN' : 'ES'}]
            </a>
            <div class="relative">
              <button id="font-size-toggle" aria-haspopup="true" aria-expanded="false" class="hover:text-electric transition-colors duration-300 flex items-center gap-1 focus-visible:ring-1 focus-visible:ring-pure dark:focus-visible:ring-bone outline-none">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path></svg>
                [<span id="font-size-label">A</span>]
              </button>
              <!-- Dropdown Menu -->
              <div id="font-size-menu" class="absolute bottom-full left-0 mb-2 hidden flex-col bg-pure dark:bg-bone text-bone dark:text-stone shadow-lg z-50 text-xs w-32 border border-pure dark:border-bone">
                <button data-size="0" class="px-4 py-3 text-left hover:bg-electric dark:hover:bg-gray-300 transition-colors duration-300 focus:bg-electric focus:outline-none w-full border-b border-bone/20 dark:border-stone/20">A- <span class="opacity-50">({lang === 'es' ? 'Pequeño' : 'Small'})</span></button>
                <button data-size="1" class="px-4 py-3 text-left hover:bg-electric dark:hover:bg-gray-300 transition-colors duration-300 focus:bg-electric focus:outline-none w-full border-b border-bone/20 dark:border-stone/20">A <span class="opacity-50">({lang === 'es' ? 'Normal' : 'Normal'})</span></button>
                <button data-size="2" class="px-4 py-3 text-left hover:bg-electric dark:hover:bg-gray-300 transition-colors duration-300 focus:bg-electric focus:outline-none w-full border-b border-bone/20 dark:border-stone/20">A+ <span class="opacity-50">({lang === 'es' ? 'Grande' : 'Large'})</span></button>
                <button data-size="3" class="px-4 py-3 text-left hover:bg-electric dark:hover:bg-gray-300 transition-colors duration-300 focus:bg-electric focus:outline-none w-full">A++ <span class="opacity-50">({lang === 'es' ? 'Extra' : 'Extra'})</span></button>
              </div>
            </div>
          </div>
        </div>
        <div class="hidden md:block font-mono text-xs text-stone dark:text-gray-500 mt-auto">
          <p class="mb-2 uppercase opacity-70">SYS. STATUS: <span class="text-electric font-bold">ONLINE</span></p>
          <p class="uppercase opacity-70">LOC: {t('hero.location')}</p>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="relative h-full text-base min-w-0">
        <slot />
      </main>
      
      <!-- Right gutter/decorative & Image -->
      <aside class="hidden md:flex flex-col border-tech-l bg-bone dark:bg-stone transition-colors duration-300 sticky top-0 h-screen overflow-hidden">
        <div class="p-6 h-full flex flex-col items-center">
          <div class="w-full aspect-square mb-8">
            <img src="/profile.png" alt="Pablo Torres" fetchpriority="high" loading="eager" class="w-full h-full object-cover rounded-none grayscale contrast-125 border border-pure dark:border-bone opacity-90 mix-blend-multiply dark:mix-blend-normal" />
          </div>
          <div class="mt-auto font-mono text-xs text-stone dark:text-gray-500 flex flex-col gap-2">
            <span>BUILD 001.0 //</span>
            <span>DATA STREAM</span>
          </div>
        </div>
      </aside>
    </div>

    <!-- Mobile Menu Fullscreen Overlay -->
    <div id="mobile-overlay" class="md:hidden fixed inset-0 z-[100] bg-bone dark:bg-stone flex flex-col justify-center items-center opacity-0 pointer-events-none transition-all duration-300 transform translate-y-4">
      <button id="mobile-close-btn" class="absolute top-6 right-6 font-mono text-sm uppercase hover:text-electric transition-colors duration-300 focus-visible:text-electric outline-none p-2 font-bold">
        [X] CLOSE
      </button>
      
      <nav class="flex flex-col gap-8 font-mono text-3xl uppercase text-center items-center tracking-tighter">
        <a href="#about" class="mobile-link hover:text-electric transition-colors duration-300 outline-none focus-visible:text-electric">{t('nav.about')}</a>
        <a href="#projects" class="mobile-link hover:text-electric transition-colors duration-300 outline-none focus-visible:text-electric">{t('nav.projects')}</a>
        <a href="#skills" class="mobile-link hover:text-electric transition-colors duration-300 outline-none focus-visible:text-electric">{t('nav.skills')}</a>
        <a href="#experience" class="mobile-link hover:text-electric transition-colors duration-300 outline-none focus-visible:text-electric">{t('nav.experience')}</a>
        <a href="#contact" class="mobile-link hover:text-electric transition-colors duration-300 outline-none focus-visible:text-electric">{t('nav.contact')}</a>
      </nav>

      <div class="mt-16 flex gap-10 font-mono text-base items-center">
        <button id="theme-toggle-mobile-menu" class="hover:text-electric transition-colors duration-300 outline-none focus-visible:text-electric">
          <span class="dark:hidden">[DARK MODE]</span>
          <span class="hidden dark:inline">[LIGHT MODE]</span>
        </button>
        <a href={lang === 'es' ? '/en' : '/'} class="hover:text-electric transition-colors duration-300 outline-none focus-visible:text-electric font-bold">
          [{lang === 'es' ? 'EN' : 'ES'}]
        </a>
      </div>
    </div>

    <script is:inline>
      const handleToggleClick = () => {
        const style = document.createElement('style');
        style.textContent = '*, ::before, ::after { transition: none !important; }';
        document.head.appendChild(style);

        const toggle = () => {
          const element = document.documentElement;
          element.classList.toggle("dark");
          const isDark = element.classList.contains("dark");
          localStorage.setItem("theme", isDark ? "dark" : "light");
        };

        if (document.startViewTransition) {
          const transition = document.startViewTransition(toggle);
          transition.finished.finally(() => style.remove());
        } else {
          toggle();
          setTimeout(() => style.remove(), 0);
        }
      }
      document.querySelectorAll("#theme-toggle, #theme-toggle-mobile-menu").forEach(btn => btn?.addEventListener("click", handleToggleClick));

      // Mobile Menu Logic
      const mobileBtn = document.getElementById('mobile-menu-btn');
      const closeBtn = document.getElementById('mobile-close-btn');
      const overlay = document.getElementById('mobile-overlay');
      const mobileLinks = document.querySelectorAll('.mobile-link');

      const toggleMenu = () => {
        if (!overlay) return;
        const isOpen = !overlay.classList.contains('opacity-0');
        if (isOpen) {
          overlay.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
          overlay.classList.remove('translate-y-0');
          document.body.style.overflow = '';
        } else {
          overlay.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
          overlay.classList.add('translate-y-0');
          document.body.style.overflow = 'hidden'; // prevent scrolling
        }
      };

      mobileBtn?.addEventListener('click', toggleMenu);
      closeBtn?.addEventListener('click', toggleMenu);
      mobileLinks.forEach(link => link.addEventListener('click', toggleMenu));

      // Font size logic
      const fontSizes = ['14px', '16px', '18px', '20px'];
      const fontSizeLabels = ['A-', 'A', 'A+', 'A++'];
      
      let currentSizeIdx = 1; // Default to 16px (A)
      
      const savedSize = localStorage.getItem('fontSize');
      if (savedSize !== null) {
        currentSizeIdx = parseInt(savedSize, 10);
      }
      
      const updateFontSize = () => {
        document.documentElement.style.fontSize = fontSizes[currentSizeIdx];
        const labelEl = document.getElementById('font-size-label');
        if (labelEl) labelEl.textContent = fontSizeLabels[currentSizeIdx];
        localStorage.setItem('fontSize', currentSizeIdx.toString());
      };
      
      updateFontSize(); // Apply on load

      const fontToggleBtn = document.getElementById('font-size-toggle');
      const fontMenu = document.getElementById('font-size-menu');

      if (fontToggleBtn && fontMenu) {
        // Toggle menu on click
        fontToggleBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          fontMenu.classList.toggle('hidden');
          fontMenu.classList.toggle('flex');
          const isExpanded = fontMenu.classList.contains('flex');
          fontToggleBtn.setAttribute('aria-expanded', isExpanded.toString());
        });

        // Handle menu item clicks
        const menuButtons = fontMenu.querySelectorAll('button[data-size]');
        menuButtons.forEach(btn => {
          btn.addEventListener('click', (e) => {
            const size = parseInt((e.currentTarget).getAttribute('data-size'), 10);
            if (!isNaN(size)) {
              currentSizeIdx = size;
              updateFontSize();
            }
            // Close menu
            fontMenu.classList.add('hidden');
            fontMenu.classList.remove('flex');
            fontToggleBtn.setAttribute('aria-expanded', 'false');
          });
        });

        // Close menu when clicking outside
        document.addEventListener('click', (e) => {
          if (!fontMenu.contains(e.target) && !fontToggleBtn.contains(e.target)) {
            fontMenu.classList.add('hidden');
            fontMenu.classList.remove('flex');
            fontToggleBtn.setAttribute('aria-expanded', 'false');
          }
        });
      }

    </script>
  </body>
</html>
